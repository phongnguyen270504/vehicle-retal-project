<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý xe</title>
    <link rel="stylesheet" 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" 
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" 
    crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/style.css">
<style>

       body{
            margin:0;

            min-height:100vh;

            display:flex;
        }

        
        /* MAIN */
        .main{
            flex:1;

            background:#f5f6f8;

            display:flex;

            flex-direction:column;
        }

        </style>
</head>
<body>
    <%- include('../partials/sidebar')  %>
    <div class="main">
    <%- include('../partials/topbar') %>
        <div class="content">
        <h1>Quản lý xe</h1>
        <a href="/cars/create" class="btn btn-primary mb-3">
            + Thêm xe
        </a>
        <!-- Table content will go here -->
         <div class="table-box">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Car rows will be dynamically inserted here -->
                     <!-- ROW -->
                      <% cars.forEach(car => { %>
                    <tr>

                        <td><%= car.id %></td>

                        <td>

                            <img
                                src="https://images.unsplash.com/photo-1503376780353-7e6692767b70"
                            >

                        </td>

                        <td><%= car.name %></td>

                        <td><%= car.pricePerDay %></td>

                        <td>
                            <% 
                            if(car.status === 'available') { %>
                                <span class="badge bg-success">
                                    Available
                                </span>
                            <% }
                            if(car.status === 'rented') { %>
                                <span class="badge bg-danger">
                                    Rented
                                </span>
                            <% } 
                            if(car.status === 'maintenance') { %>
                                <span class="badge bg-secondary">
                                    Maintenance
                                </span>
                            <% } %>
                        </td>

                        <td>

                            <a href="/cars/<%= car.id %>/update" class="btn btn-warning btn-sm">
                                Edit
                            </a>
                            <form action="/cars/<%= car.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirmDelete();">
                                <button class="btn btn-danger btn-sm" type="submit">
                                    Delete
                                </button>
                            </form>

                        </td>

                    </tr>
                    <% }) %>

                    <!-- ROW -->
                </tbody>
            </table>
         </div>
         <%- include('../partials/pagination', { totalPages, currentPage }) %>
    </div>
    </div>
</body>
<script>
    // Add any necessary JavaScript functionality here
    function confirmDelete() {
       return confirm('Are you sure you want to delete this car?');
    }
</script>
</html>