<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/style.css">
    <style>

        body{
            margin:0;

            min-height:100vh;

            display:flex;
        }

        
        /* MAIN */
        .main{
            flex:1;

            background:#f5f6f8;

            display:flex;

            flex-direction:column;
        }


        
        </style>
</head>
<body>
    <%- include('../partials/sidebar') %>
    <div class="main">
        <%- include('../partials/topbar') %>
        <div class="content">

        <div class="row g-4">

            <!-- CARD -->
            <div class="col-md-4">

                <div class="card-box">

                    <h5>
                        Total Cars
                    </h5>

                    <h2>
                        25
                    </h2>

                </div>

            </div>

            <!-- CARD -->
            <div class="col-md-4">

                <div class="card-box">

                    <h5>
                        Total Users
                    </h5>

                    <h2>
                        120
                    </h2>

                </div>

            </div>

            <!-- CARD -->
            <div class="col-md-4">

                <div class="card-box">

                    <h5>
                        Total Bookings
                    </h5>

                    <h2>
                        48
                    </h2>

                </div>

            </div>
        </div>
    </div>
    </div>
</body>
</html>