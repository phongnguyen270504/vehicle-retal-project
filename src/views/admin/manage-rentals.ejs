<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý đơn thuê</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/style.css">
    <style>
        body{
            margin:0;

            min-height:100vh;

            display:flex;
        }

        /* MAIN */
        .main{
            flex:1;

            background:#f5f6f8;

            display:flex;

            flex-direction:column;
        }
        </style>
</head>
<body>
    <%- include('../partials/sidebar')  %>
    <div class="main">
        <%- include('../partials/topbar') %>
        <div class="content">
            <h2>Quản lý đơn thuê</h2>
            <!-- Content for managing rentals -->
            <div class="table-box">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Car</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% rentals.forEach(rental => { %>
                        <tr>
                            <td><%= rental.id %></td>
                            <td><%= rental.car ? rental.car.name : 'N/A' %></td>
                            <td><%= rental.startDate.toLocaleDateString() %></td>
                            <td><%= rental.endDate.toLocaleDateString() %></td>
                            <td><%= rental.status %></td>
                            <td>
                                <a href="/admin/rentals/<%= rental.id %>" class="btn btn-sm btn-info">View</a>
                                <a href="/admin/rentals/<%= rental.id %>/edit" class="btn btn-sm btn-primary">Edit</a>
                                <a href="/admin/rentals/<%= rental.id %>/delete" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
            <!-- Pagination -->
        </div>
    </div>
</body>
</html>