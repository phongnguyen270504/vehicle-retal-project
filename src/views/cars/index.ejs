<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
         body{
            background:#f5f6f8;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main{
            flex: 1;
        }
       
    </style>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <%- include("../partials/header.ejs") %>
    <main class="main container">
        <h2>Danh sách xe</h2>
            <div class="my-2">
            <form method="GET" action="/cars">
                <div class="row g-2">
                    <div class="col-md-10">
                        <input
                            type="text"
                            class="form-control"
                            name="name"
                            placeholder="Nhập tên xe..."
                            value="<%= currentName || '' %>"
                        >
                    </div>

                    <div class="col-md-2 d-grid">
                        <button class="btn btn-primary">
                            Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>
        <div class="car-list row">
            <!-- Car items will be dynamically inserted here -->  
          <% cars.forEach(car => { %>
            <div class="car-item col-md-4 col-sm-6 mb-4">
                <div class="car-card card p-3">

                    <img
                        src="<%= car.image %>"
                        alt="<%= car.name %>"
                        class="img-fluid rounded"
                    >

                    <a class="link text-decoration-none text-dark text-truncate" href="/cars/<%= car.id %>">
                        <h4 class="mt-3"><%= car.name %></h4>
                    </a>

                    <p class="text-muted"><%= car.pricePerDay %> VND / day</p> 
                    <a class="btn btn-primary text-white" role="button" href="/cars/<%= car.id %>/booking">Thuê xe</a>
                </div>
            </div>

         <%})  %> 
        
        </div>
             <%- include("../partials/pagination.ejs", 
             {
                 totalPages, 
                currentPage,
                }) %>
</main>
    <%- include("../partials/footer.ejs") %>
</body>
</html>