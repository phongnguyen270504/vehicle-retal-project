<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cập nhật xe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/style.css">
    <style>
         body{
            margin:0;

            min-height:100vh;

            display:flex;
        }

        /* MAIN */
        .main{
            flex:1;

            background:#f5f6f8;

            display:flex;

            flex-direction:column;
        }
        </style>
</head>
<body>
     <%- include('../partials/sidebar')  %>
    <div class="main">
        <%- include('../partials/topbar') %>
        <div class="content">
            <h1><%= title %></h1>
            <div class="form-box">
                <form action="/cars/<%= result.id %>/update" method="POST" >
                    <div class="mb-3">
                        <label for="name" class="form-label">Tên xe</label>
                        <input type="text" class="form-control" id="name" name="name" value="<%= result.name %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="price" class="form-label">Giá thuê (VND/ngày)</label>
                        <input type="number" class="form-control" id="price" name="pricePerDay" value="<%= result.pricePerDay %>" required>
                    </div>
                    <div class="mb-3">
                        <label for="brand" class="form-label">Hãng xe</label>
                        <input type="text" class="form-control" id="brand" name="brand" value="<%= result.brand %>">
                    </div>
                    <div class="mb-3">
                        <label for="type" class="form-label">Loại xe</label>
                        <input type="text" class="form-control" id="type" name="type" value="<%= result.type %>">
                    </div>
                        <div class="mb-3">
                            <label for="status" class="form-label">Trạng thái</label>
                            <select class="form-select" id="status" name="status">
                                <option value="available" <%= result.status === 'available' ? 'selected' : '' %>>Có sẵn</option>
                                <option value="rented" <%= result.status === 'rented' ? 'selected' : '' %>>Đang thuê</option>
                                <option value="maintenance" <%= result.status === 'maintenance' ? 'selected' : '' %>>Bảo trì</option>
                            </select>
                        </div>
                    <div class="mb-3">
                        <label for="image" class="form-label">Ảnh xe</label>
                        <input type="file" class="form-control" id="image" name="image" accept="image/*">
                    </div>
                    <button type="submit" class="btn btn-primary">Cập nhật xe</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>