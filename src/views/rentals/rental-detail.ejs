<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết đơn hàng</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/style.css">
    <style>
        body{
            margin:0;

            min-height:100vh;

            display:flex;
        }

        /* MAIN */
        .main{
            flex:1;

            background:#f5f6f8;

            display:flex;

            flex-direction:column;
        }
        </style>
</head>
<body>
    <%- include('../partials/sidebar') %>
    <div class="main">
        <%- include('../partials/topbar') %>
        <div class="content">
            <h2>Chi tiết đơn hàng</h2>
            <div class="rental-info">
                <p><strong>Mã đơn hàng:</strong> <%= rental.id %></p>
                <p><strong>Ngày bắt đầu:</strong> <%= rental.startDate ? rental.startDate.toLocaleDateString() : 'N/A' %></p>
                <p><strong>Ngày kết thúc:</strong> <%= rental.endDate ? rental.endDate.toLocaleDateString() : 'N/A' %></p>
                <p><strong>Trạng thái:</strong><span class="badge bg-primary"><%= rental.status %></span></p>
            </div>
            <div class="table-box">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Car rows will be dynamically inserted here -->
                     <!-- ROW -->
                    <tr>


                        <td>

                            <img
                                src="https://images.unsplash.com/photo-1503376780353-7e6692767b70"
                            >

                        </td>

                        <td><%= rental.car.name %></td>

                        <td><%= rental.car.pricePerDay %></td>

                    </tr>
                    <!-- ROW -->
                </tbody>
            </table>
         </div>
         <p><strong>Tổng cộng:</strong> <%= rental.totalPrice %> VND</p>
         <div>
            <% if(rental.status ==='pending') { %>
            <form action="/rentals/<%= rental.id %>/confirm" method="POST" style="display:inline-block;">
                <button class="btn btn-primary">
                Duyệt đơn hàng
            </button>
            </form>
            <form action="/rentals/<%= rental.id %>/cancel" method="POST" style="display:inline-block;">
                <button class="btn btn-danger">
                Hủy đơn hàng
            </button>
            </form>
            <% } %>
            <% if(rental.status === 'active')  { %>
            <form action="/rentals/<%= rental.id %>/complete" method="POST" style="display:inline-block;">
                <button class="btn btn-primary">
                    Hoàn thành đơn hàng
                </button>
            </form>
            <% } %>
         </div>
        </div>
</body>
</html>