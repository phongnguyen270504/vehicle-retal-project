<div class="topbar d-flex justify-content-between">

        <h4>
            <% if (title) {%>
                <%= title %>
            <% } else { %>
                Dashboard
            <% } %>
        </h4>

        <div>
            <% if (user) { %>
            <span class="me-3">Hello, Admin</span>
            <a href="/auth/logout" class="btn btn-outline-secondary btn-sm">
                Logout
            </a>
            <% } else { %>
                <a href="/auth/login" class="btn btn-outline-primary btn-sm">
                    Login
                </a>
            <% } %>
        </div>

    </div>